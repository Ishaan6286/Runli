# Runli — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to git.

# ─────────────────────────────────────────
# AI
# ─────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here   # fallback LLM (free at console.groq.com)

# ─────────────────────────────────────────
# Authentication
# ─────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_secret
SESSION_SECRET=another_long_random_secret

# ─────────────────────────────────────────
# Database
# ─────────────────────────────────────────
# Local (Docker Compose): mongodb://mongodb:27017/runli
# Production (Atlas):     mongodb+srv://user:pass@cluster.mongodb.net/runli
MONGODB_URI=mongodb://mongodb:27017/runli

# ─────────────────────────────────────────
# Redis
# ─────────────────────────────────────────
# Local (Docker Compose): redis://redis:6379
# Production (ElastiCache): redis://your-elasticache-endpoint:6379
REDIS_URI=redis://redis:6379

# ─────────────────────────────────────────
# Service URLs
# ─────────────────────────────────────────
# Local: http://localhost:8000
# Docker Compose (internal): http://ai-service:8000
# Production: https://ai.yourdomian.com
AI_SERVICE_URL=http://localhost:8000

FRONTEND_URL=http://localhost:5173
PORT=5001

# ─────────────────────────────────────────
# OAuth (Google)
# ─────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5001/api/auth/google/callback

# ─────────────────────────────────────────
# AWS (Production only — CI/CD)
# ─────────────────────────────────────────
# AWS_ACCOUNT_ID=123456789012
# AWS_REGION=ap-south-1

# ─────────────────────────────────────────
# Razorpay (Subscriptions)
# ─────────────────────────────────────────
# Get these from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Create plans in the Razorpay dashboard and paste the plan IDs here:
# Dashboard → Subscriptions → Plans → Create Plan
RAZORPAY_PRO_PLAN_ID=plan_xxxxxxxxxxxx
RAZORPAY_ELITE_PLAN_ID=plan_xxxxxxxxxxxx

# Generate a random webhook secret and paste it here.
# Then add it to: Razorpay Dashboard → Settings → Webhooks
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here
